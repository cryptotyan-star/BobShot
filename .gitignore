node_modules/
.pnpm-store/
.yarn/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# Сборки
.next/
dist/
build/
out/

# Системные
.DS_Store
Thumbs.db

