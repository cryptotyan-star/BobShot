# Секреты и локальные настройки — никогда не коммитить
.env
.env.local
.env.*
.env.*.local
*.pem
*.key

# Но шаблоны переменных окружения — наоборот, держим в git (без секретов внутри).
!.env.example
!.env.*.example

# Локальные настройки Claude Code (личные, не для git).
# Пример settings.local.json.example НЕ игнорируется — он остаётся в git как образец.
.claude/settings.local.json

# .business/ — приватный бизнес-контекст, заполнен реальными данными при онбординге.
# Не должен попадать в репозиторий.
.business/

