.vitest-cache/

# Playwright
playwright-report/
test-results/

# report-kit — генерируемые PDF и временный файл рендера.
# Исходники (css/html/mjs/fonts) держим в git; собранные отчёты — нет.
templates/report-kit/*.pdf
templates/report-kit/.render-*.html

